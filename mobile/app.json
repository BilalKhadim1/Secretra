{
  "expo": {
    "name": "Secretra",
    "slug": "personal-secretary-hr",
    "version": "1.0.0",
    "scheme": "personal-secretary",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.bilal.secretra",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "personal-secretary"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.bilal.secretra",
      "supportsTablet": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ff93509-c749-4589-b32f-739fb1ea105a"
      }
    }
  }
}