{
  "expo": {
    "name": "Secretra",
    "slug": "personal-secretary-hr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "scheme": "com.bilal.secretra",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.bilal.secretra",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.bilal.secretra"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.bilal.secretra",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.bilal.secretra",
              "com.googleusercontent.apps.32854911840-f607ufse7v03l19ht797i08mp2a0qtna"
            ]
          }
        ]
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbf18342-d16e-4d15-b6bc-9765238062c4"
      }
    }
  }
}
