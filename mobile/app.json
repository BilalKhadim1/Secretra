{
  "expo": {
    "name": "Secretra",
    "slug": "personal-secretary-hr",
    "version": "1.0.0",
    "scheme": "com.bilal.secretra",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.bilal.secretra",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.bilal.secretra"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.bilal.secretra",
      "supportsTablet": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbf18342-d16e-4d15-b6bc-9765238062c4"
      }
    }
  }
}
