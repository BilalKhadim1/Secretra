{
  "expo": {
    "name": "Secretra",
    "slug": "personal-secretary",
    "version": "1.0.0",
    "scheme": "personal-secretary",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.bilal.secretra",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "personal-secretary"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.bilal.secretra",
      "supportsTablet": true
    }
  }
}
