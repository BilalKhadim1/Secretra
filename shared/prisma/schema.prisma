// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventPriority {
  critical
  high
  medium
  low
}

enum EventStatus {
  proposed
  confirmed
  cancelled
}

enum TaskPriority {
  critical
  high
  medium
  low
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum InteractionType {
  call
  email
  meeting
  note
}

enum DraftStatus {
  draft
  sent
  scheduled
}

enum PlatformType {
  web
  ios
  android
}

enum GroupMemberStatus {
  pending
  accepted
}

model User {
  id               String              @id @default(uuid()) @db.Uuid
  email            String              @unique
  password         String?
  name             String?
  timezone         String              @default("UTC")
  digestTime       DateTime?           @db.Time
  avatarUrl         String?
  theme             String              @default("dark")
  notificationsEnabled Boolean          @default(true) @map("notifications_enabled")
  // OAuth
  googleId         String?             @unique @map("google_id")
  appleId          String?             @unique @map("apple_id")
  oauthAccounts    OAuthAccount[]
  // Features
  pushSubscriptions PushSubscription[]
  events           Event[]
  tasks            Task[]
  reminders        Reminder[]
  notes            Note[]
  contacts         Contact[]
  groups           Group[]
  groupMembers     GroupMember[]
  emailDrafts      EmailDraft[]
  emailTemplates   EmailTemplate[]
  attendedEvents   Event[]             @relation("EventAttendees")
  eventAttendances EventAttendance[]


  createdAt        DateTime            @default(now()) @db.Timestamptz
  updatedAt        DateTime            @updatedAt @db.Timestamptz
  deletedAt        DateTime?           @db.Timestamptz

  @@map("users")
}

model OAuthAccount {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  providerId   String   @map("provider_id")
  accessToken  String   @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiresAt    DateTime? @db.Timestamptz @map("expires_at")
  createdAt    DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model PushSubscription {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  PlatformType
  endpoint  String       @unique
  keys      Json?
  deviceId  String?      @map("device_id")
  createdAt DateTime     @default(now()) @db.Timestamptz @map("created_at")

  @@map("push_subscriptions")
}

model Event {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId       String?       @db.Uuid @map("group_id")
  group         Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  eventType     String        @default("event") @map("event_type")
  startAt       DateTime      @db.Timestamptz @map("start_at")
  endAt         DateTime      @db.Timestamptz @map("end_at")
  isAllDay      Boolean       @default(false) @map("is_all_day")
  priority      EventPriority @default(medium)
  status        EventStatus   @default(confirmed)
  googleEventId String?       @unique @map("google_event_id")
  rrule         String?
  location      String?
  color         String?
  reminderMinutes Int?          @map("reminder_minutes")
  tasks         Task[]
  reminders     Reminder[]
  attendees     User[]        @relation("EventAttendees")
  attendances   EventAttendance[]
  createdAt     DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime      @updatedAt @db.Timestamptz @map("updated_at")

  @@map("events")
}

model EventAttendance {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @db.Uuid @map("event_id")
  userId    String   @db.Uuid @map("user_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now()) @db.Timestamptz @map("joined_at")

  @@unique([eventId, userId])
  @@map("event_attendances")
}

model Group {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?       @map("description")
  imageUrl    String?       @map("image_url")
  events      Event[]
  members     GroupMember[]
  createdAt   DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime      @updatedAt @db.Timestamptz @map("updated_at")

  @@map("groups")
}

model GroupMember {
  id        String              @id @default(uuid()) @db.Uuid
  groupId   String              @db.Uuid @map("group_id")
  email     String              @db.Text
  userId    String?             @db.Uuid @map("user_id")
  status    GroupMemberStatus   @default(accepted) @map("status")
  group     Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now()) @db.Timestamptz @map("created_at")

  @@unique([groupId, email])
  @@map("group_members")
}

model Contact {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid @map("user_id")
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  emails          String[]             @default([])
  phones          String[]             @default([])
  company         String?
  role            String?
  tags            String[]             @default([])
  avatarUrl       String?              @map("avatar_url")
  googleContactId String?              @map("google_contact_id")
  // FTS search vector (handled by SQL direct)
  // searchVector Unsupported("tsvector")? 
  tasks           Task[]
  notes           Note[]
  interactions    ContactInteraction[]
  emailDrafts     EmailDraft[]

  createdAt       DateTime             @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime             @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt       DateTime?            @db.Timestamptz @map("deleted_at")

  @@map("contacts")
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  priority        TaskPriority @default(medium)
  status          TaskStatus   @default(todo)
  startDate       DateTime?    @db.Timestamptz @map("start_date")
  dueDate         DateTime?    @db.Timestamptz @map("due_date")
  sortOrder       String?      @map("sort_order")
  eventId         String?      @db.Uuid @map("event_id")
  event           Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  contactId       String?      @db.Uuid @map("contact_id")
  contact         Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reminderMinutes Int?         @map("reminder_minutes")
  reminders       Reminder[]

  googleEventId String?       @unique @map("google_event_id")
  createdAt       DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt       DateTime?    @db.Timestamptz @map("deleted_at")

  @@map("tasks")
}

model Reminder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fireAt    DateTime @db.Timestamptz @map("fire_at")
  bullJobId String?  @map("bull_job_id")
  sent      Boolean  @default(false)
  taskId    String?  @db.Uuid @map("task_id")
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventId   String?  @db.Uuid @map("event_id")
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("reminders")
}

model Note {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String?
  content      Json
  plainText    String?   @map("plain_text")
  aiSummary    String?   @map("ai_summary")
  contactId    String?   @db.Uuid @map("contact_id")
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  tags         String[]  @default([])
  folder       String?
  isPinned     Boolean   @default(false) @map("is_pinned")
  isArchived   Boolean   @default(false) @map("is_archived")
  // FTS search vector (handled by SQL direct)
  createdAt    DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt    DateTime  @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt    DateTime? @db.Timestamptz @map("deleted_at")

  @@map("notes")
}

model ContactInteraction {
  id               String          @id @default(uuid()) @db.Uuid
  contactId        String          @db.Uuid @map("contact_id")
  contact          Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type             InteractionType
  summary          String?
  happenedAt       DateTime        @default(now()) @db.Timestamptz @map("happened_at")
  linkedEntityId   String?         @db.Uuid @map("linked_entity_id")
  linkedEntityType String?         @map("linked_entity_type")
  createdAt        DateTime        @default(now()) @db.Timestamptz @map("created_at")

  @@map("contact_interactions")
}

model EmailDraft {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid @map("user_id")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId       String?     @db.Uuid @map("contact_id")
  contact         Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  subject         String?
  body            String?
  status          DraftStatus @default(draft)
  sendAt          DateTime?   @db.Timestamptz @map("send_at")
  gmailMessageId  String?     @map("gmail_message_id")
  createdAt       DateTime    @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime    @updatedAt @db.Timestamptz @map("updated_at")

  @@map("email_drafts")
}

model EmailTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String?  @map("body_template")
  variables       String[] @default([])
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("email_templates")
}
