// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventPriority {
  critical
  high
  medium
  low
}

enum EventStatus {
  proposed
  confirmed
  cancelled
}

enum TaskPriority {
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum InteractionType {
  call
  email
  meeting
  note
}

enum DraftStatus {
  draft
  sent
  scheduled
}

enum PlatformType {
  web
  ios
  android
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  password          String?
  name              String?
  timezone          String             @default("UTC")
  digestTime        DateTime?          @db.Time
  avatarUrl         String?
  // OAuth
  googleId          String?            @unique @map("google_id")
  appleId           String?            @unique @map("apple_id")
  oauthAccounts     OAuthAccount[]
  // Features
  pushSubscriptions PushSubscription[]
  events            Event[]
  tasks             Task[]
  reminders         Reminder[]
  notes             Note[]
  contacts          Contact[]
  emailDrafts       EmailDraft[]
  emailTemplates    EmailTemplate[]

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@map("users")
}

model OAuthAccount {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  providerId   String    @map("provider_id")
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model PushSubscription {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  PlatformType
  endpoint  String
  keys      Json?
  deviceId  String?      @map("device_id")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@map("push_subscriptions")
}

model Event {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  startAt       DateTime      @map("start_at") @db.Timestamptz
  endAt         DateTime      @map("end_at") @db.Timestamptz
  isAllDay      Boolean       @default(false) @map("is_all_day")
  priority      EventPriority @default(medium)
  status        EventStatus   @default(confirmed)
  googleEventId String?       @map("google_event_id")
  rrule         String?
  location      String?
  color         String?
  tasks         Task[]
  reminders     Reminder[]
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  @@map("events")
}

model Contact {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  emails          String[]             @default([])
  phones          String[]             @default([])
  company         String?
  role            String?
  tags            String[]             @default([])
  avatarUrl       String?              @map("avatar_url")
  googleContactId String?              @map("google_contact_id")
  // FTS search vector (handled by SQL direct)
  // searchVector Unsupported("tsvector")? 
  tasks           Task[]
  notes           Note[]
  interactions    ContactInteraction[]
  emailDrafts     EmailDraft[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@map("contacts")
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    TaskPriority @default(P3)
  status      TaskStatus   @default(todo)
  dueDate     DateTime?    @map("due_date") @db.Timestamptz
  sortOrder   String?      @map("sort_order")
  eventId     String?      @map("event_id") @db.Uuid
  event       Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  contactId   String?      @map("contact_id") @db.Uuid
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reminders   Reminder[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@map("tasks")
}

model Reminder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fireAt    DateTime @map("fire_at") @db.Timestamptz
  bullJobId String?  @map("bull_job_id")
  sent      Boolean  @default(false)
  taskId    String?  @map("task_id") @db.Uuid
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventId   String?  @map("event_id") @db.Uuid
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("reminders")
}

model Note {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   Json
  plainText String?   @map("plain_text")
  aiSummary String?   @map("ai_summary")
  contactId String?   @map("contact_id") @db.Uuid
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  // FTS search vector (handled by SQL direct)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@map("notes")
}

model ContactInteraction {
  id               String          @id @default(uuid()) @db.Uuid
  contactId        String          @map("contact_id") @db.Uuid
  contact          Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type             InteractionType
  summary          String?
  happenedAt       DateTime        @default(now()) @map("happened_at") @db.Timestamptz
  linkedEntityId   String?         @map("linked_entity_id") @db.Uuid
  linkedEntityType String?         @map("linked_entity_type")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz

  @@map("contact_interactions")
}

model EmailDraft {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId      String?     @map("contact_id") @db.Uuid
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  subject        String?
  body           String?
  status         DraftStatus @default(draft)
  sendAt         DateTime?   @map("send_at") @db.Timestamptz
  gmailMessageId String?     @map("gmail_message_id")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@map("email_drafts")
}

model EmailTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String?  @map("body_template")
  variables       String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("email_templates")
}
